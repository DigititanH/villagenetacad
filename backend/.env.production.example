# Production template for villagenetacad.co.za — copy to backend/.env on the server
# Full guide: DEPLOYMENT.md  |  Prefilled template: deploy/env.production.template

PORT=5000
NODE_ENV=production

# VPS (Afrihost): /var/lib/village-netacad/...
# Azure App Service: /home/site/data/... (see deploy/azure/env.azure.template)
DATABASE_PATH=/var/lib/village-netacad/database.sqlite
UPLOADS_DIR=/var/lib/village-netacad/uploads
JWT_SECRET=REPLACE_WITH_openssl_rand_hex_32
JWT_EXPIRES_IN=7d

CLIENT_URL=https://villagenetacad.co.za
API_URL=https://villagenetacad.co.za

PAYFAST_MERCHANT_ID=14050025
PAYFAST_MERCHANT_KEY=YOUR_SANDBOX_OR_LIVE_KEY
PAYFAST_PASSPHRASE=YOUR_PASSPHRASE
PAYFAST_SANDBOX=true
PAYFAST_NOTIFY_URL=https://villagenetacad.co.za/api/payfast/notify

SITE_EMAIL=info@villagenetacad.co.za
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@villagenetacad.co.za
SMTP_PASS=YOUR_GMAIL_APP_PASSWORD
