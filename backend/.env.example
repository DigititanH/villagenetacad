PORT=5000
NODE_ENV=development

# SQLite (optional — defaults to backend/database.sqlite)
# DATABASE_PATH=./database.sqlite
# UPLOADS_DIR=./uploads

# JWT — use a long random string in production (32+ chars)
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
JWT_EXPIRES_IN=7d

# Public URLs (required in production)
CLIENT_URL=http://localhost:5173
API_URL=http://localhost:5000

# PayFast — https://sandbox.payfast.co.za (test) or www.payfast.co.za (live)
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=true
# HTTPS webhook for payment confirmation (required on live server)
# PAYFAST_NOTIFY_URL=https://yourdomain.com/api/payfast/notify

# Cloudinary (optional — product images fall back to local uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (SMTP)
SITE_EMAIL=info@villagenetacad.co.za
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Stripe (optional — PayFast is the primary gateway)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
