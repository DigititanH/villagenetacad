{
  "name": "village-netacad-backend",
  "version": "1.0.0",
  "description": "Village NetAcad API server",
  "main": "src/server.js",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "node scripts/check-node.js && nodemon src/server.js",
    "postinstall": "node scripts/install-sqlite.js",
    "start": "node src/server.js",
    "db:migrate": "node src/database/migrate.js",
    "build:frontend": "npm run build --prefix ../frontend",
    "predeploy": "npm run db:migrate && npm run build:frontend",
    "deploy": "node src/server.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.10.0",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.15",
    "pdfkit": "^0.18.0",
    "stripe": "^17.3.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
