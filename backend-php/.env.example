# Village NetAcad PHP API — copy to .env
# cp .env.example .env

PORT=5000
NODE_ENV=development

# SQLite DB and uploads (relative to backend-php/ or absolute paths)
DATABASE_PATH=database.sqlite
UPLOADS_DIR=uploads

# Generate for production: openssl rand -hex 32
JWT_SECRET=dev-secret-change-in-production-use-openssl-rand-hex-32
JWT_EXPIRES_IN=7d

# React frontend origin(s), comma-separated
CLIENT_URL=http://localhost:5173
API_URL=http://localhost:5000

# PayFast sandbox (set PAYFAST_SANDBOX=false for live)
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=true
PAYFAST_NOTIFY_URL=http://localhost:5000/api/payfast/notify

SITE_EMAIL=info@villagenetacad.co.za
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Production example (Afrihost VPS):
# NODE_ENV=production
# DATABASE_PATH=/var/lib/village-netacad/database.sqlite
# UPLOADS_DIR=/var/lib/village-netacad/uploads
# CLIENT_URL=https://villagenetacad.co.za
# API_URL=https://villagenetacad.co.za
# PAYFAST_NOTIFY_URL=https://villagenetacad.co.za/api/payfast/notify
