# Village NetAcad — copy to .env (filename must be .env NOT .env.txt)
# Local:  copy .env.example .env
# cPanel: use deploy/env.cpanel.template → upload as backend-php/.env

PORT=5000
NODE_ENV=development

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=village_netacad
DB_USER=root
DB_PASSWORD=

UPLOADS_DIR=uploads

JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=7d

CLIENT_URL=http://localhost:5173
API_URL=http://localhost:5000

PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_SANDBOX=true
PAYFAST_NOTIFY_URL=http://localhost:5000/api/payfast/notify

SITE_EMAIL=info@villagenetacad.co.za
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
