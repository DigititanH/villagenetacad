# Copy any of these into your existing .env to enable the matching feature.
# The app runs fine without them — missing notification creds simply log
# what would have been sent.

# ---- Supabase (frontend + backend) ----
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_PUBLISHABLE_KEY="eyJ..."
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJ..."
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"

# ---- Frontend → FastAPI backend ----
# Where the React app calls the FastAPI backend from the browser.
VITE_API_BASE="http://127.0.0.1:8000"

# ---- Public site URL (used in admin notification links) ----
PUBLIC_SITE_URL="http://localhost:8082"

# ---- Admin notifications ----
# Who receives the alert when a new reseller application arrives.
ADMIN_EMAIL="admin@example.com"
# Twilio uses the "whatsapp:+E164" format.
ADMIN_WHATSAPP_TO="whatsapp:+27821234567"

# ---- Email via Resend (https://resend.com) ----
# 1. Sign up at resend.com (free tier covers most fundraising volumes).
# 2. Add a sender domain or use the onboarding "resend.dev" sender.
# 3. Copy your API key here.
RESEND_API_KEY="re_..."
NOTIFICATION_FROM_EMAIL="Village NetAcad <notifications@yourdomain.org>"

# ---- WhatsApp via Twilio (https://www.twilio.com/whatsapp) ----
# Easiest way to start: enable the Twilio WhatsApp Sandbox.
#   - SID + auth token live in the Twilio console.
#   - The sandbox sender is whatsapp:+14155238886.
#   - Each phone that receives messages must first join the sandbox
#     by texting the join code to that number.
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
