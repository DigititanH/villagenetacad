# Village NetAcad — production (Afrihost)
# Copy to backend-php/.env on the server:
#   cp deploy/env.production.template backend-php/.env

NODE_ENV=production

# Writable paths outside public/ (recommended on cPanel/VPS)
DATABASE_PATH=/home/YOUR_USER/village-netacad-data/database.sqlite
UPLOADS_DIR=/home/YOUR_USER/village-netacad-data/uploads

# Or relative to backend-php/ (must be writable by PHP):
# DATABASE_PATH=../database.sqlite
# UPLOADS_DIR=../uploads

# Generate NEW secret: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_OPENSSL_RAND_HEX_32
JWT_EXPIRES_IN=7d

CLIENT_URL=https://villagenetacad.co.za
API_URL=https://villagenetacad.co.za

PAYFAST_MERCHANT_ID=10048872
PAYFAST_MERCHANT_KEY=YOUR_MERCHANT_KEY_FROM_PAYFAST
PAYFAST_SANDBOX=true
PAYFAST_NOTIFY_URL=https://villagenetacad.co.za/api/payfast/notify
# PAYFAST_PASSPHRASE=only_if_enabled_in_payfast_security

SITE_EMAIL=info@villagenetacad.co.za
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@villagenetacad.co.za
SMTP_PASS=YOUR_GMAIL_APP_PASSWORD
