# Azure App Service → Configuration → Application settings
# Copy each KEY=value (without # comments) into the portal.
# Replace YOUR_APP with your app name, e.g. villagenetacad

NODE_ENV=production
WEBSITE_NODE_DEFAULT_VERSION=~22
SCM_DO_BUILD_DURING_DEPLOYMENT=true

# Persistent storage on Linux App Service (/home survives restarts)
DATABASE_PATH=/home/site/data/database.sqlite
UPLOADS_DIR=/home/site/data/uploads

# Public URLs — use custom domain after binding
CLIENT_URL=https://YOUR_APP.azurewebsites.net
API_URL=https://YOUR_APP.azurewebsites.net

JWT_SECRET=REPLACE_WITH_openssl_rand_hex_32
JWT_EXPIRES_IN=7d

PAYFAST_MERCHANT_ID=14050025
PAYFAST_MERCHANT_KEY=YOUR_SANDBOX_OR_LIVE_KEY
PAYFAST_PASSPHRASE=YOUR_PASSPHRASE
PAYFAST_SANDBOX=true
PAYFAST_NOTIFY_URL=https://YOUR_APP.azurewebsites.net/api/payfast/notify

SITE_EMAIL=info@villagenetacad.co.za
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@villagenetacad.co.za
SMTP_PASS=YOUR_GMAIL_APP_PASSWORD

# Optional: Cloudinary for product images
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
